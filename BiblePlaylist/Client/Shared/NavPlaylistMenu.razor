@using BiblePlaylist.Client.Config
@using BiblePlaylist.Shared.Data
@using BiblePlaylist.Shared.Playlist
@using BiblePlaylist.Client.Events
@using BiblePlaylist.Shared.DTO
@using Microsoft.Extensions.Logging
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime js
@inject ILogger<NavBibleMenu> logger
@inject IDelegateLibrary delegateLibrary
@inject Endpoints endpoints



<MudGrid Class="mt-1" id="menuGrid" hidden="@(!hide)">
    <MudItem md="4" xs="12">
        <h3 @onclick="ToggleMenu">@selectedPlaylist?.Description</h3>
    </MudItem>
    <MudItem md="4" xs="12">
        <h3 @onclick="ToggleMenu">@chapterText</h3>
    </MudItem>    
    <MudItem md="4" xs="3">
        <MudToggleIconButton @bind-Toggled="Autoplay" 
        Icon="@Icons.Material.Filled.Autorenew"
        ToggledIcon="@Icons.Material.Filled.Autorenew"
        Color="@Color.Default"
        ToggledColor="@Color.Primary"
        Title="Toggle Autoplay"
        />
    </MudItem>
    <MudItem md="4" xs="3">
        <MudToggleIconButton @bind-Toggled="Repeat"
        Icon="@Icons.Material.Filled.Repeat"
        ToggledIcon="@Icons.Material.Filled.RepeatOn"
        Color="@Color.Default"
        ToggledColor="@Color.Primary"
        Title="Toggle Repeat"
         />        
    </MudItem>
</MudGrid>
<MudGrid hidden="@(!hide)" Class="mt-1 stickyAudio">
    <MudItem md="4" xs="12">
        <MudFab hidden="@HasPlayed" StartIcon="@Icons.Material.Filled.PlayCircle" Size="Size.Medium" OnClick="LoadAudio"></MudFab>
        <audio id="fullChapterAudioPlayer" hidden="@(!HasPlayed)" controls>
            <source id="fullChapterAudioSource" src="" type="audio/mpeg">
            Your browser does not support the audio element.
        </audio>
    </MudItem>
</MudGrid>
<MudGrid hidden="@(!hide)" Class="mt-1 stickyChapterNav">
    <MudItem md="4" xs="3">
        <MudFab StartIcon="@Icons.Material.Filled.ChevronLeft" Color="@Color.Dark" @onclick="ChapterBack" Size="Size.Small" />
    </MudItem>
    <MudItem md="4" xs="3">
        <MudFab StartIcon="@Icons.Material.Filled.ChevronRight" Color="@Color.Dark" @onclick="ChapterForward" Size="Size.Small" />
    </MudItem>

</MudGrid>
<MudGrid Class="mt-1" hidden="@(!hide)">
    <MudItem xs="12">
        <MudList T="string">
            @if (Library != null)
            {            
                foreach (var p in Library.Playlists)
                {
                    <MudListItem @onclick="@(e => SelectPlaylist(p))" id="@p.Name.Replace(" ","_")">@p.Name</MudListItem>
                    @if (Library != null && !hideChapters && selectedPlaylist.Name == p.Name)
                    {
                        <MudItem xs="12" hidden="@hideChapters">
                            <MudGrid>
                                @if (selectedPlaylist != null)
                                {                                   
                                    @if (selectedPlaylist.BookChapters == null || !selectedPlaylist.BookChapters.Any())
                                    {
                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">
                                            No chapters loaded yet.
                                        </MudAlert>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.h5" GutterBottom="true" Class="mb-4">
                                            @PlaylistName
                                        </MudText>

                                        <MudExpansionPanels MultiExpand="true">
                                            @foreach (var chapter in selectedPlaylist.BookChapters)
                                            {
                                                <MudExpansionPanel Text="@chapter.Display">
                                                    <ChildContent>
                                                        <MudPaper Elevation="1" Class="pa-4 mb-4" Outlined="true">
                                                            <MudGrid>
                                                                <MudItem xs="12" sm="8">
                                                                    <MudText Typo="Typo.subtitle1" Color="Color.Primary">
                                                                        @chapter.VoiceText
                                                                    </MudText>
                                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                                        @(chapter.Segments?.Count == 1 ? "1 segment" : $"{chapter.Segments?.Count ?? 0} segments")
                                                                    </MudText>
                                                                </MudItem>
                                                                <MudItem xs="12" sm="4" Class="d-flex justify-end align-center">
                                                                    @if (chapter.Segments?.Any() == true)
                                                                    {
                                                                        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                                                                   StartIcon="@Icons.Material.Filled.PlayArrow">
                                                                            Play Chapter
                                                                        </MudButton>
                                                                    }
                                                                </MudItem>
                                                            </MudGrid>
                                                        </MudPaper>

                                                        @if (chapter.Segments == null || !chapter.Segments.Any())
                                                        {
                                                            <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense="true">
                                                                No segments defined for this chapter.
                                                            </MudAlert>
                                                        }
                                                        else
                                                        {
                                                            <MudList Dense="true" Clickable="false">
                                                                @foreach (var segment in chapter.Segments.OrderBy(s => s.VerseStart))
                                                                {
                                                                    <MudListItem>
                                                                        <ChildContent>
                                                                            <!-- Header / title line for the segment -->
                                                                            <MudText Typo="Typo.subtitle2" Class="mb-1">
                                                                                @segment.VoiceText
                                                                            </MudText>
                                                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                                                                                Verses @segment.VerseStart@(segment.VerseStart == segment.VerseEnd ? "" : $"–{segment.VerseEnd}")
                                                                            </MudText>

                                                                            <!-- Verse container -->
                                                                            <div class="verse-container mt-2 mb-4 pl-4 border-l-4 border-primary"
                                                                                 style="border-color: var(--mud-palette-primary); background-color: rgba(0,0,0,0.02); border-radius: 4px; padding: 12px;">
                                                                                @foreach (var verse in segment.Verses)
                                                                                {
                                                                                    <div class="d-flex align-start mb-3">
                                                                                        <MudText Typo="Typo.body2"
                                                                                                 Class="verse-number mr-4 font-weight-medium"
                                                                                                 Color="Color.Secondary">
                                                                                            @verse.Number
                                                                                        </MudText>
                                                                                        <div class="flex-grow-1 verse-text">
                                                                                            @((MarkupString)verse.Html)
                                                                                        </div>
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </ChildContent>
                                                                    </MudListItem>
                                                                }
                                                            </MudList>
                                                        }
                                                    </ChildContent>
                                                </MudExpansionPanel>
                                            }
                                        </MudExpansionPanels>
                                    }
                                }
                            </MudGrid>
                        </MudItem>
                    }
                }           
            }
        </MudList>
    </MudItem>


</MudGrid>
<MudPaper Class="mb-5">

</MudPaper>

@code {
    private BiblePlaylist.Shared.DTO.SelectedBookChapter SelectedBookChapter { get; set; }    
    private bool HasPlayed { get; set; } = false;    
    private BiblePlaylist.Shared.Navigation.BibleMenu bibleMenu { get; set; }
    private string chapterText { get; set; }
    private string chapterAudio { get; set; }
    private string selectedBookRef { get; set; }
    private bool hide { get; set; } = true;
    private bool hideChapters { get; set; } = true;
    private bool hideVerses { get; set; } = true;
    private bool _autoplay { get; set; } = false;   
    private bool loadAudio { get; set; } = true;
    private BiblePlaylist.Shared.Data.UserSettings userSettings;
    private bool _repeat = false;

    private bool Autoplay
    {
        get => _autoplay;
        set
        {
            _autoplay = value;
            Task.Run(async () => await AutoplayChanged(_autoplay));
        }
    }

    private bool Repeat
    {
        get => _repeat;
        set
        {
            _repeat = value;
            Task.Run(async () => await RepeatChanged(_repeat));
        }
    }

    private Library Library { get; set; }
    private Playlist selectedPlaylist { get; set; }
    [Parameter]
    public string PlaylistName { get; set; }
    protected override async Task OnParametersSetAsync()
    {       
        if (userSettings == null)
            userSettings = await localStorage.GetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings");

        if (userSettings == null)
        {
            userSettings = new BiblePlaylist.Shared.Data.UserSettings { Autoplay = _autoplay, Repeat = _repeat };
            await localStorage.SetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings", userSettings);
        }

        Autoplay = userSettings.Autoplay;
        Repeat = userSettings.Repeat;
        await InvokeAsync(StateHasChanged);
        await base.OnParametersSetAsync();

    }

    protected override async Task OnInitializedAsync()
    {        
        string libraryResponse = await Http.GetStringAsync("library?key=library_greg_hardin_live_com");
        Library = JsonConvert.DeserializeObject<Library>(libraryResponse);
        selectedPlaylist = Library.Playlists.FirstOrDefault(pl => pl.Name == PlaylistName);
        delegateLibrary.HasPlayedChanged += (o, e) => OnHasPlayedChanged(e.Value);
        await base.OnInitializedAsync();
    }

    private void OnHasPlayedChanged(bool value)
    {
        HasPlayed = value;
        StateHasChanged();
    }

    protected async Task ToggleMenu()
    {
        hide = !hide;

        if (!hide)
        {
            var navSelectedBook = SelectedBookChapter.SelectedBook;
            if (navSelectedBook > 2)
            {
                navSelectedBook = navSelectedBook - 2;
                var navBook = bibleMenu.Books.Where(b => b.Number == navSelectedBook).FirstOrDefault();
                await js.InvokeVoidAsync("NavToBook", $"#{navBook.Name.Replace(" ", "_")}");
            }
            else
                await js.InvokeVoidAsync("ScrollToTop");
        }
    }

    protected async Task LoadAudio()
    {
        await js.InvokeVoidAsync("LoadAudioFile", "fullChapterAudioPlayer", "fullChapterAudioSource", chapterAudio, true);
        HasPlayed = true;
    }

    protected async Task ChapterBack()
    {
        if (SelectedBookChapter.SelectedChapter != 1)
        {
            SelectedBookChapter.SelectedChapter--;
        }
        else if (SelectedBookChapter.SelectedBook != 1)
        {
            SelectedBookChapter.SelectedBook--;
            SelectedBookChapter.SelectedChapter = bibleMenu.Books.Where(b => b.Number == SelectedBookChapter.SelectedBook).FirstOrDefault().Chapters.Max(c => c.Number);
        }
        else
            return;

        await SelectBookChapter();
    }

    protected async Task ChapterForward()
    {
        int lastChapter = bibleMenu.Books.Where(b => b.Number == SelectedBookChapter.SelectedBook).FirstOrDefault().Chapters.Max(c => c.Number);

        if (SelectedBookChapter.SelectedChapter != lastChapter)
        {
            SelectedBookChapter.SelectedChapter++;
        }
        else if (SelectedBookChapter.SelectedBook != 66)
        {
            SelectedBookChapter.SelectedBook++;
            SelectedBookChapter.SelectedChapter = 1;
        }
        else
            return;

        await SelectBookChapter();
    }

    protected async Task SelectPlaylist(Playlist playlist)
    {
        loadAudio = false;

        selectedPlaylist = playlist;
        var bookChaptersResponse = await Http.PostAsJsonAsync<IList<BookChapter>>("playlist/inflate?key=NET", selectedPlaylist.BookChapters);
        List<BookChapter> inflatedBookChapters = new List<BookChapter>();
        if (bookChaptersResponse.IsSuccessStatusCode)
          inflatedBookChapters = await bookChaptersResponse.Content.ReadFromJsonAsync<List<BookChapter>>();

        selectedPlaylist.BookChapters.Clear();
        inflatedBookChapters.ForEach(bc => selectedPlaylist.BookChapters.Add(bc));

        //chapterText = selectedPlaylist.BookChapters.FirstOrDefault().BookNumber.ToString();                
        hideChapters = !hideChapters;
    }

    protected async Task SelectBookChapter(BookChapter bookChapter, bool toggleMenu = true)
    {
        if(toggleMenu)
            hideVerses = !hideVerses;

        SelectedBookChapter.SelectedChapter = bookChapter.ChapterNumber;
        SelectedBookChapter.SelectedBook = bookChapter.BookNumber;
        var selectedBook = bibleMenu.Books.FirstOrDefault(b => b.Number == SelectedBookChapter.SelectedBook);
        var selectedBookName = selectedBook.Name;
        var selectedBookRef = $"#{selectedBookName.Replace(" ", "_")}";
        chapterText = $"{selectedBook.Name} {SelectedBookChapter.SelectedChapter}";
        chapterAudio = $"{endpoints.Audio}{bookChapter.Chapter?.AudioUrl}";

        if (toggleMenu)
        {
            hideChapters = !hideChapters;
            hide = !hide;
        }
        await InvokeAsync(StateHasChanged);        
        try
        {
            HasPlayed = true;
            loadAudio = true;
            await js.InvokeVoidAsync("LoadAudioFile", "fullChapterAudioPlayer", "fullChapterAudioSource", chapterAudio, _autoplay, _repeat);
        }
        catch (Exception ex) 
        {
            logger.LogError(ex, "Audio already loaded");
        }
       
        await js.InvokeVoidAsync("ScrollToTop");
        delegateLibrary.NotifyChapterChanged(this, new BiblePlaylist.Client.Delegates.EventArgs<SelectedBookChapter>(SelectedBookChapter));
    }

    private async Task SelectBookChapter()
    {        
        await SelectBookChapter(selectedPlaylist.BookChapters
            .FirstOrDefault(bc => bc.ChapterNumber == SelectedBookChapter.SelectedChapter && bc.BookNumber == SelectedBookChapter.SelectedBook), false);
    }

    private async Task AutoplayChanged(bool newState)
    {
        userSettings.Autoplay = newState;
        await localStorage.SetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings", userSettings);
    }

    private async Task RepeatChanged(bool newState)
    {
        userSettings.Repeat = newState;
        await localStorage.SetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings", userSettings);
    }

    [JSInvokable]
    public async Task ChapterEnded()
    {
        if (_repeat)
        {
            await js.InvokeVoidAsync("LoadAudioFile", "fullChapterAudioPlayer", "fullChapterAudioSource", chapterAudio, _autoplay, _repeat);
            return;
        }

        if (_autoplay)
            await ChapterForward();
    }
}
