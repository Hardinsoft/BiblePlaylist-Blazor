@using BiblePlaylist.Client.Config
@using BiblePlaylist.Client.Events
@using BiblePlaylist.Shared.DTO
@using Microsoft.Extensions.Logging
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime js
@inject ILogger<NavBibleMenu> logger
@inject IDelegateLibrary delegateLibrary
@inject Endpoints endpoints

<MudGrid Class="mt-1" id="menuGrid">
    <MudItem md="4" xs="12">
        <h3 @onclick="ToggleMenu">@chapterText</h3>
    </MudItem>   
    <MudItem md="4" xs="3">
        <MudToggleIconButton @bind-Toggled="Autoplay" 
        Icon="@Icons.Material.Filled.Autorenew"
        ToggledIcon="@Icons.Material.Filled.Autorenew"
        Color="@Color.Default"
        ToggledColor="@Color.Primary"
        title="Toggle Autoplay"
        />
    </MudItem>
    <MudItem md="4" xs="3">
        <MudToggleIconButton @bind-Toggled="Repeat"
        Icon="@Icons.Material.Filled.Repeat"
        ToggledIcon="@Icons.Material.Filled.RepeatOn"
        Color="@Color.Default"
        ToggledColor="@Color.Primary"
        title="Toggle Repeat"
        />        
    </MudItem>
</MudGrid>
<MudGrid hidden="@(!hide)" Class="mt-1 stickyAudio">
    <MudItem md="4" xs="12">
        <MudFab hidden="@HasPlayed" StartIcon="@Icons.Material.Filled.PlayCircle" Size="Size.Medium" OnClick="LoadAudio"></MudFab>
        <audio id="fullChapterAudioPlayer" hidden="@(!HasPlayed)" controls>
            <source id="fullChapterAudioSource" src="" type="audio/mpeg">
            Your browser does not support the audio element.
        </audio>
    </MudItem>
</MudGrid>
<MudGrid hidden="@(!hide)" Class="mt-1 stickyChapterNav">
    <MudItem md="4" xs="3">
        <MudFab StartIcon="@Icons.Material.Filled.ChevronLeft" Color="@Color.Dark" @onclick="ChapterBack" Size="Size.Small" />
    </MudItem>
    <MudItem md="4" xs="3">
        <MudFab StartIcon="@Icons.Material.Filled.ChevronRight" Color="@Color.Dark" @onclick="ChapterForward" Size="Size.Small" />
    </MudItem>

</MudGrid>
<MudGrid Class="mt-1" hidden="@hide">
    <MudItem xs="12">
        <MudList T="string">
            @if (bibleMenu != null)
            {            
                foreach (var b in bibleMenu.Books)
                {
                    <MudListItem @onclick="@(e => SelectBook(b))" id="@b.Name.Replace(" ","_")">@b.Name</MudListItem>
                    @if (bibleMenu != null && !hideChapters && SelectedBookChapter.SelectedBook == b.Number)
                    {
                        <MudItem xs="12" hidden="@hideChapters">
                            <MudGrid>
                                @if (bibleMenu != null)
                                {                                   
                                    foreach (var c in bibleMenu.Books.FirstOrDefault(b => b.Number == SelectedBookChapter.SelectedBook).Chapters)
                                    {
                                        <MudItem md="1" xs="2">
                                            <MudPaper @onclick="@(async e => await SelectChapter(c))" Style="cursor: pointer" Class="d-flex align-center justify-center mud-width-full py-4">@c.Number</MudPaper>
                                        </MudItem>
                                    }
                                }
                            </MudGrid>
                        </MudItem>
                    }
                }           
            }
        </MudList>
    </MudItem>
</MudGrid>
<MudPaper Class="mb-5">

</MudPaper>

@code {
    private BiblePlaylist.Shared.DTO.SelectedBookChapter SelectedBookChapter { get; set; }    
    private bool HasPlayed { get; set; } = false;    
    private BiblePlaylist.Shared.Navigation.BibleMenu bibleMenu { get; set; }
    private string chapterText { get; set; }
    private string chapterAudio { get; set; }
    private string selectedBookRef { get; set; }
    private bool hide { get; set; } = true;
    private bool hideChapters { get; set; } = true;
    private bool hideVerses { get; set; } = true;
    private bool _autoplay = false;   
    private bool loadAudio { get; set; } = true;    
    private BiblePlaylist.Shared.Data.UserSettings userSettings;
    private DotNetObjectReference<NavBibleMenu> objRef;
    private bool _netObjectIsSet = false;
    private bool _repeat = false;
    private BiblePlaylist.Shared.Bible.Version lastRead;

    private bool Autoplay
    {
        get => _autoplay;
        set
        {
            _autoplay = value;
            Task.Run(async () => await AutoplayChanged(_autoplay));
        }
    }

    private bool Repeat
    {
        get => _repeat;
        set
        {
            _repeat = value;
            Task.Run(async () => await RepeatChanged(_repeat));
        }
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (objRef == null)
            objRef = DotNetObjectReference.Create(this);

        try
        {
            if (!_netObjectIsSet)
            {
                await js.InvokeVoidAsync("SetNetObject", objRef);
                _netObjectIsSet = true;
                await js.InvokeVoidAsync("console.log", "SetNetObject Set");
            }
        }
        catch (System.Exception ex)
        {
            await js.InvokeVoidAsync("console.log", $"SetNetObject failed {ex.Message}");
        }

        await js.InvokeVoidAsync("console.log", "NavBibleMenu afterrender called");

        await base.OnAfterRenderAsync(firstRender);

    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(chapterText) && SelectedBookChapter != null)
        {
            if (bibleMenu == null)
                await SetBibleMenu();

            if (lastRead == null)
                lastRead = await localStorage.GetItemAsync<BiblePlaylist.Shared.Bible.Version>("userName_lastread");

            if (lastRead != null)
            {
                var selectedBook = lastRead.Books.FirstOrDefault();
                var selectedChapter = lastRead.Books.FirstOrDefault().Chapters.FirstOrDefault();
                var selectedBookName = selectedBook.Name;
                var selectedBookRef = $"#{selectedBookName.Replace(" ", "_")}";
                chapterText = $"{selectedBookName} {selectedChapter.Number}";
                chapterAudio = $"{endpoints.Audio}{ selectedChapter.AudioUrl}";
            }

            if (userSettings == null)
                userSettings = await localStorage.GetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings");

            if (userSettings == null)
            {
                userSettings = new BiblePlaylist.Shared.Data.UserSettings { Autoplay = Autoplay, Repeat = Autoplay };
                await localStorage.SetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings", userSettings);
            }

            Autoplay = userSettings.Autoplay;
            Repeat = userSettings.Repeat;

            await InvokeAsync(StateHasChanged);            
            
        }
        await base.OnParametersSetAsync();
    }    

    protected override async Task OnInitializedAsync()
    {
        
        if (SelectedBookChapter == null)
        {
            if (lastRead == null)
                lastRead = await localStorage.GetItemAsync<BiblePlaylist.Shared.Bible.Version>("userName_lastread");

            if (lastRead == null || lastRead.Books == null)
            {
                var lastReadResponse = await Http.GetAsync($"Version?key={BiblePlaylist.Shared.Structs.Version.NET}&Book=1&Chapter=1");
                lastRead = await lastReadResponse.Content.ReadFromJsonAsync<BiblePlaylist.Shared.Bible.Version>();
                await localStorage.SetItemAsync<BiblePlaylist.Shared.Bible.Version>("userName_lastread", lastRead);
            }

            var lastBook = lastRead.Books.FirstOrDefault();
            SelectedBookChapter = new BiblePlaylist.Shared.DTO.SelectedBookChapter() { SelectedBook = lastBook.Number, SelectedChapter = lastBook.Chapters.FirstOrDefault().Number };               

            await InvokeAsync(StateHasChanged);
        }
        delegateLibrary.HasPlayedChanged += (o, e) => OnHasPlayedChanged(e.Value);

        await base.OnInitializedAsync();
    }

    private void OnHasPlayedChanged(bool value)
    {
        HasPlayed = value;
        StateHasChanged();
    }

    protected async Task ToggleMenu()
    {
        hide = !hide;

        if (!hide)
        {
            var navSelectedBook = SelectedBookChapter.SelectedBook;
            if (navSelectedBook > 2)
            {
                navSelectedBook = navSelectedBook - 2;
                var navBook = bibleMenu.Books.Where(b => b.Number == navSelectedBook).FirstOrDefault();
                await js.InvokeVoidAsync("NavToBook", $"#{navBook.Name.Replace(" ", "_")}");
            }
            else
                await js.InvokeVoidAsync("ScrollToTop");
        }
    }

    protected async Task LoadAudio()
    {
        await js.InvokeVoidAsync("LoadAudioFile", "fullChapterAudioPlayer", "fullChapterAudioSource", chapterAudio, true);
        HasPlayed = true;
    }

    protected async Task ChapterBack()
    {
        if (SelectedBookChapter.SelectedChapter != 1)
        {
            SelectedBookChapter.SelectedChapter--;
        }
        else if (SelectedBookChapter.SelectedBook != 1)
        {
            SelectedBookChapter.SelectedBook--;
            if (bibleMenu == null)
                await SetBibleMenu();
            SelectedBookChapter.SelectedChapter = bibleMenu.Books.Where(b => b.Number == SelectedBookChapter.SelectedBook).FirstOrDefault().Chapters.Max(c => c.Number);
        }
        else
            return;

        await SelectChapter();
    }

    protected async Task ChapterForward()
    {
        if (bibleMenu == null)
            await SetBibleMenu();

        int lastChapter = bibleMenu.Books.Where(b => b.Number == SelectedBookChapter.SelectedBook).FirstOrDefault().Chapters.Max(c => c.Number);

        if (SelectedBookChapter.SelectedChapter != lastChapter)
        {
            SelectedBookChapter.SelectedChapter++;
        }
        else if (SelectedBookChapter.SelectedBook != 66)
        {
            SelectedBookChapter.SelectedBook++;
            SelectedBookChapter.SelectedChapter = 1;
        }
        else
            return;

        await SelectChapter();
    }

    protected void SelectBook(BiblePlaylist.Shared.Navigation.NavBook book)
    {
        loadAudio = false;                   

        SelectedBookChapter.SelectedBook = book.Number;
        hideChapters = !hideChapters;
    }

    protected async Task SelectChapter(BiblePlaylist.Shared.Navigation.NavChapter chapter, bool toggleMenu = true)
    {
        if(toggleMenu)
            hideVerses = !hideVerses;

        if (bibleMenu == null)
            await SetBibleMenu();

        SelectedBookChapter.SelectedChapter = chapter.Number;
        var selectedBook = bibleMenu.Books.FirstOrDefault(b => b.Number == SelectedBookChapter.SelectedBook);
        var selectedBookName = selectedBook.Name;
        var selectedBookRef = $"#{selectedBookName.Replace(" ", "_")}";
        chapterText = $"{selectedBook.Name} {SelectedBookChapter.SelectedChapter}";
        chapterAudio = $"{endpoints.Audio}{chapter.AudioUrl}";

        if (toggleMenu)
        {
            hideChapters = !hideChapters;
            hide = !hide;
        }
        await InvokeAsync(StateHasChanged);        
        try
        {
            HasPlayed = true;
            loadAudio = true;
            await js.InvokeVoidAsync("LoadAudioFile", "fullChapterAudioPlayer", "fullChapterAudioSource", chapterAudio, _autoplay, _repeat);
        }
        catch (Exception ex) 
        {
            logger.LogError(ex, "Audio already loaded");
        }

        await js.InvokeVoidAsync("ScrollToTop");
        
        delegateLibrary.NotifyChapterChanged(this, new BiblePlaylist.Client.Delegates.EventArgs<SelectedBookChapter>(SelectedBookChapter));
    }

    private async Task SelectChapter()
    {
        if (bibleMenu == null)
            await SetBibleMenu();

        var audioURL = bibleMenu.Books.Where(b => b.Number == SelectedBookChapter.SelectedBook).FirstOrDefault().Chapters.Where(c => c.Number == SelectedBookChapter.SelectedChapter).FirstOrDefault().AudioUrl;
        await SelectChapter(new BiblePlaylist.Shared.Navigation.NavChapter() { Number = SelectedBookChapter.SelectedChapter, AudioUrl = audioURL }, false);
    }

    private async Task AutoplayChanged(bool newState)
    {        
        userSettings.Autoplay = newState;
        await localStorage.SetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings", userSettings);
    }

    private async Task RepeatChanged(bool newState)
    {        
        userSettings.Repeat = newState;
        await localStorage.SetItemAsync<BiblePlaylist.Shared.Data.UserSettings>("userName_settings", userSettings);
    }

    private async Task SetBibleMenu()
    {
        var lastReadResponse = await Http.GetAsync($"BibleMenu?key={BiblePlaylist.Shared.Structs.BibleMenu.Name}");
        bibleMenu = await lastReadResponse.Content.ReadFromJsonAsync<BiblePlaylist.Shared.Navigation.BibleMenu>();
    }

    [JSInvokable]
    public async Task ChapterEnded()
    {
        if (_repeat)
        {
            await js.InvokeVoidAsync("LoadAudioFile", "fullChapterAudioPlayer", "fullChapterAudioSource", chapterAudio, _autoplay, _repeat);
            return;
        }

        if (_autoplay)
            await ChapterForward();
    }

    

}
